fight:82F8 abs_x_to_proximity_rel proc near        ; ...
fight:82F8                 mov     bx, ax          ; ax=bx=inX (absolute x coord in the map)
fight:82FA                 sub     ax, ds:proximity_map_left_col_x ; ax = inX-proximityLeft
fight:82FE                 jb      short inX_lt_proxLeft ;
fight:82FE                                         ; case0:
fight:82FE                                         ; proximityLeft <= inX < mapWidth
fight:8300                 xchg    ax, bx          ; ax = inX
fight:8300                                         ; bx = inX - proximityLeft
fight:8301                 mov     ax, 36-3
fight:8304                 sub     ax, bx          ; ax = 33 - (inX - proximityLeft)
fight:8304                                         ; bx = inX - proximityLeft
fight:8306                 retn                    ; CF if: proximityLeft + 34 <= inX
fight:8306                                         ; NC if: proximityLeft <= inX < proximityLeft + 34
fight:8307 ; ---------------------------------------------------------------------------
fight:8307
fight:8307 inX_lt_proxLeft:                        ; ...
fight:8307                 mov     ax, 36-3        ; case1:
fight:8307                                         ; inX < proximityLeft
fight:830A                 sub     ax, bx          ; ax = 33 - inX
fight:830A                                         ; bx = inX
fight:830C                 jnb     short inX_le_33
fight:830E                 retn                    ; CF if: 33 < inX < proximityLeft
fight:830F ; ---------------------------------------------------------------------------
fight:830F
fight:830F inX_le_33:                              ; ...
fight:830F                 mov     ax, ds:mapWidth ; case2:
fight:830F                                         ; inX <= 33 < proximityLeft
fight:8312                 sub     ax, ds:proximity_map_left_col_x
fight:8316                 add     ax, bx          ; ax = mapWidth - proximity_map_left_col_x + inX
fight:8316                                         ; bx = inX
fight:8318                 xchg    ax, bx          ; ax = inX
fight:8318                                         ; bx = mapWidth - proximity_map_left_col_x + inX
fight:8319                 mov     ax, 36-3
fight:831C                 sub     ax, bx          ; ax = 33 - (mapWidth - proximity_map_left_col_x + inX)
fight:831C                                         ; bx = mapWidth - proximity_map_left_col_x + inX
fight:831E                 retn                    ; CF if: 33 - inX < mapWidth - proximity_map_left_col_x
fight:831E abs_x_to_proximity_rel endp
