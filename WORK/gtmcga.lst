seg000:394F                 mov     cs:[di+2], dh
seg000:3953                 mov     bx, 1000        ; dl:ax < 10000
seg000:3956                 call    divmod24        ; DH = DL:AX / BX
seg000:3956                                         ; AX = DL:AX % BX
seg000:3959                 mov     cs:[di+3], dh
seg000:395D                 mov     bx, 100         ; dl:ax < 1000
seg000:3960                 call    divmod24        ; DH = DL:AX / BX
seg000:3960                                         ; AX = DL:AX % BX
seg000:3963                 mov     cs:[di+4], dh
seg000:3967                 mov     bx, 10          ; dl:ax < 100
seg000:396A                 call    divmod24        ; DH = DL:AX / BX
seg000:396A                                         ; AX = DL:AX % BX
seg000:396D                 mov     cs:[di+5], dh
