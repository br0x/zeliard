seg000:398F ; DH = DL:AX / BX
seg000:398F ; AX = DL:AX % BX
seg000:398F
seg000:398F divmod24        proc near               ; ...
seg000:398F                 xor     dh, dh
seg000:3991                 div     bx              ; 00:DL:AX / BX -> AX
seg000:3991                                         ; 00:DL:AX % BX -> DX
seg000:3993                 xchg    ax, dx          ; DX = /, AX = %
seg000:3994                 mov     dh, dl          ; DH = /, AX = %
seg000:3996                 xor     dl, dl
seg000:3998                 retn
seg000:3998 divmod24        endp
