seg000:393D                 mov     bx, 100000-65536
seg000:3940                 call    high_byte_decimal_digit_extractor ; DH = DL:AX / CL:BX
seg000:3940                                         ; AX = DL:AX % CL:BX
seg000:3943                 mov     cs:[di+1], dh
seg000:3947                 xor     cl, cl
seg000:3949                 mov     bx, 10000
seg000:394C                 call    high_byte_decimal_digit_extractor ; DH = DL:AX / CL:BX
