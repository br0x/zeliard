seg000:3976 ; DH = DL:AX / CL:BX
seg000:3976 ; AX = DL:AX % CL:BX
seg000:3976
seg000:3976 high_byte_decimal_digit_extractor proc near ; ...
seg000:3976                 xor     dh, dh
seg000:3978
seg000:3978 next_sub:                               ; ...
seg000:3978                 sub     dl, cl          ; dl:ax -= cl:bx
seg000:397A                 jb      short restore_dl
seg000:397C                 sub     ax, bx
seg000:397E                 jnb     short no_carry
seg000:3980                 or      dl, dl
seg000:3982                 jz      short restore_ax
seg000:3984                 dec     dl
seg000:3986
